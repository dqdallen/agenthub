{
  "name": "agenthub",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server",
    "build": "vite build",
    "preview": "vite preview",
    "db:init": "node server/db/init.js",
    "db:seed": "node server/db/seed.js",
    "db:setup": "./setup-database.sh",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "prisma:status": "prisma migrate status",
    "start": "NODE_ENV=production node server/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop agenthub-server",
    "pm2:restart": "pm2 restart agenthub-server",
    "pm2:logs": "pm2 logs agenthub-server",
    "docker:build": "docker build -t agenthub:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:db": "docker-compose up -d postgres",
    "docker:adminer": "docker-compose up -d adminer",
    "docker:logs": "docker-compose logs -f",
    "test:forum": "node test-forum-simple.js"
  },
  "dependencies": {
    "@getbrevo/brevo": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "clsx": "^2.1.0",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^11.0.5",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.330.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.8",
    "prisma": "^5.22.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "react-syntax-highlighter": "^16.1.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0"
  },
  "prisma": {
    "seed": "node server/db/seed.js"
  }
}
