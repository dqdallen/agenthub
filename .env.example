# ==============================
# AgentHub 生产环境配置
# ==============================

# 服务器配置
PORT=3001
NODE_ENV=production

# 安全配置（必须修改！使用强密钥）
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-here-change-this-in-production
JWT_EXPIRES_IN=7d

# 数据库配置
DATABASE_URL=file:./prod.db

# CORS 配置（允许的前端域名）
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# API 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 平台配置
PLATFORM_FEE_PERCENT=10
