# ==============================
# AgentHub 生产环境配置
# ==============================

# 服务器配置
PORT=3001
NODE_ENV=production

# 安全配置（必须修改！使用强密钥）
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-here-change-this-in-production
JWT_EXPIRES_IN=7d

# 数据库配置 (PostgreSQL)
# 开发环境使用 Docker Compose 运行 PostgreSQL
DATABASE_URL=postgresql://agenthub:agenthub_password@localhost:5432/agenthub?schema=public

# 生产环境可以使用以下格式连接云数据库 (如 AWS RDS, Supabase 等)
# DATABASE_URL=postgresql://username:password@your-host:5432/agenthub?schema=public&connect_timeout=300&pool_timeout=20

# CORS 配置（允许的前端域名）
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# API 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 平台配置
PLATFORM_FEE_PERCENT=10

# ==============================
# 邮件配置
# ==============================
# 支持两种方式：Brevo API（推荐）或 SMTP
# 优先级：Brevo > SMTP > 控制台打印

# --- 方式一：Brevo API（推荐，免费版每天 300 封）---
# 注册地址: https://www.brevo.com/
# 获取 API Key: 设置 → API Key → 创建新密钥
BREVO_API_KEY=your-brevo-api-key

# --- 方式二：SMTP（传统方式）---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password

# 发件人邮箱（Brevo 需要在控制台验证，SMTP 作为 from 地址）
SMTP_FROM=noreply@yourdomain.com
