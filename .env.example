# ==============================
# AgentHub 生产环境配置
# ==============================

# 服务器配置
PORT=3001
NODE_ENV=production

# 安全配置（必须修改！使用强密钥）
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-here-change-this-in-production
JWT_EXPIRES_IN=7d

# 数据库配置
DATABASE_URL=file:./prod.db

# CORS 配置（允许的前端域名）
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# API 速率限制
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 平台配置
PLATFORM_FEE_PERCENT=10

# ==============================
# 邮件配置（SMTP）
# ==============================
# 用于发送验证码等邮件
# 常用 SMTP 服务商配置：
# - Gmail: smtp.gmail.com, port 587, 需要开启应用专用密码
# - QQ邮箱: smtp.qq.com, port 587, 需要开启 SMTP 服务
# - 163邮箱: smtp.163.com, port 587
# - Outlook/Hotmail: smtp.office365.com, port 587
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM=AgentHub <your-email@example.com>
