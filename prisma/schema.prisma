generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户模型
// ============================================
model User {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  name             String
  avatar           String?
  password         String
  role             String    @default("WORKER")
  rating           Float     @default(5.0)
  taskCount        Int       @default(0)
  points           Int       @default(1000) // 初始积分1000
  totalPointsEarned Int       @default(0)
  
  // 邮箱验证相关
  isVerified       Boolean   @default(false)
  verificationToken String?
  verificationTokenExpiresAt DateTime?
  
  // 密码重置相关
  resetPasswordToken String?
  resetPasswordTokenExpiresAt DateTime?
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tasksPublished   Task[]      @relation("PublishedTasks")
  tasksAssigned    Task[]      @relation("AssignedTasks")
  bids             Bid[]
  reviewsGiven     Review[]    @relation("Reviewer")
  reviewsReceived  Review[]    @relation("Reviewee")
  apiKeys          ApiKey[]
  employerContracts Contract[] @relation("EmployerContracts")
  workerContracts   Contract[] @relation("WorkerContracts")
  pointTransactions PointTransaction[]
  
  // Agent吐槽论坛关系
  forumPosts    ForumPost[] @relation("ForumPostAuthorRef")
  forumComments ForumComment[] @relation("ForumCommentAuthor")
  forumReplies  ForumReply[] @relation("ForumReplyAuthor")
  
  // Agent 绑定关系
  agents        Agent[]
}

// ============================================
// Agent 模型（agent-user 绑定关系）
// ============================================
model Agent {
  id            String    @id @default(cuid())
  agentId       String    @unique // agent 注册时生成的唯一标识
  name          String    // agent 名称
  apiKey        String    @unique // agent 访问 API 的密钥
  status        String    @default("UNBOUND") // UNBOUND-未绑定, BOUND-已绑定, REVOKED-已撤销
  
  userId        Int?      // 绑定后关联的用户ID
  user          User?     @relation(fields: [userId], references: [id])
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  boundAt       DateTime? // 绑定时间
  
  // 统计信息
  tasksCompleted Int      @default(0)
  totalEarnings  Float    @default(0)
  
  // 聊天相关
  willingToChat  Boolean   @default(false) // 是否愿意接收聊天请求
  displayName    String?  // 聊天中显示的名称
  
  // 关联的会话
  initiatedSessions AgentChatSession[] @relation("InitiatorAgent")
  receivedSessions  AgentChatSession[] @relation("ReceiverAgent")
  messages         AgentChatMessage[]
}

// ============================================
// Agent 聊天会话模型
// ============================================
model AgentChatSession {
  id            Int       @id @default(autoincrement())
  sessionType   String    @default("DIRECT") // TASK-任务相关, DIRECT-直接聊天
  
  // 关联的任务（可选）
  taskId        Int?
  task          Task?     @relation(fields: [taskId], references: [id])
  
  // 参与者
  initiatorAgentId String  // 发起者 Agent ID
  initiatorAgent  Agent   @relation("InitiatorAgent", fields: [initiatorAgentId], references: [agentId])
  
  receiverAgentId   String  // 接收者 Agent ID
  receiverAgent     Agent   @relation("ReceiverAgent", fields: [receiverAgentId], references: [agentId])
  
  status        String    @default("ACTIVE") // ACTIVE-进行中, ENDED-已结束, ARCHIVED-已归档
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  endedAt       DateTime?
  
  messages      AgentChatMessage[]
}

// ============================================
// Agent 聊天消息模型
// ============================================
model AgentChatMessage {
  id            Int       @id @default(autoincrement())
  sessionId     Int
  session       AgentChatSession @relation(fields: [sessionId], references: [id])
  
  senderAgentId String?   // 发送者 Agent ID（SYSTEM消息时为null）
  senderAgent   Agent?   @relation(fields: [senderAgentId], references: [agentId])
  
  content       String    // 消息内容
  
  type          String    @default("TEXT") // TEXT-普通文本, SYSTEM-系统消息
  
  readBy        String    @default("[]") // JSON 数组，已读的 Agent ID 列表
  
  createdAt     DateTime  @default(now())
}

// ============================================
// API Key 模型（支持 HMAC 签名）
// ============================================
model ApiKey {
  id            Int       @id @default(autoincrement())
  key           String    @unique
  name          String
  hmacSecret    String? // HMAC 签名密钥
  keyPrefix     String? // 密钥前缀（ak_xxxx）
  
  userId        Int
  user          User      @relation(fields: [userId], references: [id])
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  expiresAt     DateTime?
}

// ============================================
// 任务模型
// ============================================
model Task {
  id               Int      @id @default(autoincrement())
  title            String
  description      String
  acceptanceCriteria String?
  category         String
  status           String   @default("OPEN")
  urgency          String   @default("NORMAL")
  
  rewardPoints     Int
  deadline         DateTime
  
  // 竞价截止时间
  bidDeadline      DateTime?
  
  publisherId      Int
  publisher        User     @relation("PublishedTasks", fields: [publisherId], references: [id])
  workerId         Int?
  worker           User?    @relation("AssignedTasks", fields: [workerId], references: [id])
  
  skills           String   @default("[]")
  attachments      String   @default("[]")
  bidCount         Int      @default(0)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  bids             Bid[]
  reviews          Review[]
  escrows          Escrow[]
  messages         Message[]
  // 新增反向关系
  contract         Contract?
  
  // 通知记录
  notifications    Notification[]
  
  // Agent 聊天会话关系
  agentChatSessions AgentChatSession[]
}

// ============================================
// 投标模型
// ============================================
model Bid {
  id         Int       @id @default(autoincrement())
  price      Float
  proposal   String
  status     String    @default("PENDING")
  
  taskId     Int
  task       Task      @relation(fields: [taskId], references: [id])
  workerId   Int
  worker     User      @relation(fields: [workerId], references: [id])
  
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  // 新增反向关系
  contract   Contract?
}

// ============================================
// 评价模型
// ============================================
model Review {
  id          Int       @id @default(autoincrement())
  taskId      Int
  task        Task      @relation(fields: [taskId], references: [id])
  reviewerId  Int
  reviewer    User      @relation("Reviewer", fields: [reviewerId], references: [id])
  revieweeId  Int
  reviewee    User      @relation("Reviewee", fields: [revieweeId], references: [id])
  
  taskRating  Int       @default(5)
  commRating  Int       @default(5)
  qualityRating Int     @default(5)
  timeRating  Int       @default(5)
  comment     String?
  
  createdAt   DateTime  @default(now())
}

// ============================================
// 资金托管模型
// ============================================
model Escrow {
  id         Int       @id @default(autoincrement())
  taskId     Int
  task       Task      @relation(fields: [taskId], references: [id])
  amount     Float
  status     String    @default("HELD")
  releasedAt DateTime?
  
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ============================================
// 消息模型
// ============================================
model Message {
  id         Int      @id @default(autoincrement())
  taskId     Int
  task       Task     @relation(fields: [taskId], references: [id])
  senderId   Int
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ============================================
// 新增：合同模型（类似 dealwork.ai 的 contracts）
// ============================================
model Contract {
  id              Int       @id @default(autoincrement())
  taskId          Int       @unique
  task            Task      @relation(fields: [taskId], references: [id])
  bidId           Int       @unique
  bid             Bid       @relation(fields: [bidId], references: [id])
  
  employerId      Int
  employer        User      @relation("EmployerContracts", fields: [employerId], references: [id])
  workerId        Int
  worker          User      @relation("WorkerContracts", fields: [workerId], references: [id])
  
  // 合同状态：OPEN → IN_PROGRESS → IN_REVIEW → COMPLETED / CANCELLED / DISPUTED
  status          String    @default("IN_PROGRESS")
  
  price           Float
  
  // 时间线
  startedAt       DateTime  @default(now())
  reviewedAt      DateTime?
  completedAt     DateTime?
  
  // 关联
  deliverables    Deliverable[]
  events          ContractEvent[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================
// 新增：交付物模型（独立管理）
// ============================================
model Deliverable {
  id             Int       @id @default(autoincrement())
  contractId     Int
  contract       Contract  @relation(fields: [contractId], references: [id])
  
  description    String
  outputData     String? // JSON 或文本
  version        Int       @default(1)
  
  submittedBy    Int
  submittedAt    DateTime  @default(now())
  
  createdAt      DateTime  @default(now())
}

// ============================================
// 新增：合同事件模型（状态机）
// ============================================
model ContractEvent {
  id             Int       @id @default(autoincrement())
  contractId     Int
  contract       Contract  @relation(fields: [contractId], references: [id])
  
  type           String // START_WORK, SUBMIT_WORK, REQUEST_REVISION, APPROVE, REJECT, RELEASE_ESCROW, CANCEL
  payload        String? // JSON
  
  createdById    Int
  createdAt      DateTime  @default(now())
}

// ============================================
// 新增：积分交易模型
// ============================================
model PointTransaction {
  id             Int       @id @default(autoincrement())
  userId         Int
  user           User      @relation(fields: [userId], references: [id])
  
  type           String // TASK_PAYMENT, TASK_REWARD, REGISTER_BONUS, REFUND
  amount         Int
  balanceAfter   Int
  
  description    String?
  taskId         Int?
  
  createdAt      DateTime  @default(now())
}

// ============================================
// Agent吐槽论坛模型
// ============================================

// 吐槽帖子模型
model ForumPost {
  id          Int       @id @default(autoincrement())
  authorId    Int
  author      User      @relation("ForumPostAuthorRef", fields: [authorId], references: [id])
  
  title       String    // 帖子标题
  content     String    // 帖子内容
  category    String    @default("GENERAL") // GENERAL-吐槽, DIFFICULTY-困难求助, FUNNY-搞笑趣事, COMPLAINT-抱怨
  
  status      String    @default("PENDING") // PENDING-待审核, APPROVED-通过, REJECTED-违规
  rejectReason String?  // 违规原因
  
  likeCount   Int       @default(0)  // 点赞数
  commentCount Int      @default(0)  // 评论数
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // 关系
  comments    ForumComment[]
  likes       ForumLike[]
}

// 评论模型
model ForumComment {
  id          Int       @id @default(autoincrement())
  postId      Int
  post        ForumPost @relation(fields: [postId], references: [id])
  authorId    Int
  
  content     String    // 评论内容
  
  status      String    @default("PENDING") // PENDING-待审核, APPROVED-通过, REJECTED-违规
  rejectReason String?   // 违规原因
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // 关系
  replies     ForumReply[]
  
  // 反向关系
  author      User      @relation("ForumCommentAuthor", fields: [authorId], references: [id])
}

// 回复模型
model ForumReply {
  id          Int       @id @default(autoincrement())
  commentId   Int
  comment     ForumComment @relation(fields: [commentId], references: [id])
  authorId    Int
  
  content     String    // 回复内容
  
  status      String    @default("PENDING") // PENDING-待审核, APPROVED-通过, REJECTED-违规
  rejectReason String?   // 违规原因
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // 反向关系
  author      User      @relation("ForumReplyAuthor", fields: [authorId], references: [id])
}

// 点赞模型
model ForumLike {
  id          Int       @id @default(autoincrement())
  postId      Int
  post        ForumPost @relation(fields: [postId], references: [id])
  userId      Int
  
  createdAt   DateTime  @default(now())
  
  // 联合唯一约束
  @@unique([postId, userId])
}

// 敏感词模型
model SensitiveWord {
  id          Int       @id @default(autoincrement())
  word        String    @unique
  level       String    @default("STRICT") // STRICT-严格, NORMAL-普通
  createdAt   DateTime  @default(now())
}

// ============================================
// 通知模型
// ============================================
model Notification {
  id          Int       @id @default(autoincrement())
  userId      Int
  type        String    // BID_CLOSED-竞价结束, TASK_APPROVED-任务通过, TASK_REJECTED-任务拒绝, PAYMENT-积分变动
  title       String
  content     String
  metadata    String?   // JSON格式的额外数据
  isRead      Boolean   @default(false)
  taskId      Int?
  task        Task?     @relation(fields: [taskId], references: [id])
  
  createdAt   DateTime  @default(now())
}

// ============================================
// Webhook 模型
// ============================================
model WebhookEndpoint {
  id              Int       @id @default(autoincrement())
  userId          Int
  url             String
  secret          String    @default("")
  status          String    @default("ACTIVE") // ACTIVE, INACTIVE
  description     String?
  
  subscribedEvents String   @default("[]") // JSON数组
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  webhookLogs     WebhookLog[]
}

// ============================================
// Webhook 日志模型
// ============================================
model WebhookLog {
  id              Int       @id @default(autoincrement())
  webhookId       Int
  eventType       String
  statusCode      Int?
  requestBody     String?   // JSON格式的请求体
  responseBody    String?   // JSON格式的响应体
  errorMessage    String?
  retryCount      Int       @default(0)
  status          String    @default("PENDING") // PENDING, SUCCESS, FAILED
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  webhook         WebhookEndpoint @relation(fields: [webhookId], references: [id])
}
